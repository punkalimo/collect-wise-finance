{
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/sitemap.xml", "destination": "/sitemap.xml" },
    { "source": "/robots.txt", "destination": "/robots.txt" },
    { "source": "/assets/:path*", "destination": "/assets/:path*" },
    { "source": "/((?!.*\\.).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/contact.js": {
      "memory": 1024,
      "maxDuration": 30
    },
    "api/assessment.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  }
}
